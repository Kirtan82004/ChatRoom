@{
    ViewData["Title"] = "Home";
}

<div class="container py-5">

    <div class="row align-items-center min-vh-75">

        <div class="col-lg-6">

            <span class="badge bg-primary mb-3 px-3 py-2">
                Real-Time ASP.NET Core Chat App
            </span>

            <h1 class="display-3 fw-bold mb-4">
                Connect & Chat
                <span class="text-primary">
                    Instantly
                </span>
            </h1>

            <p class="lead text-muted mb-4">
                A modern real-time chat application built with
                ASP.NET Core MVC, SignalR, Entity Framework Core,
                and Identity Authentication.
            </p>

            <div class="d-flex gap-3">

                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Chat"
                           asp-action="Index"
                           class="btn btn-primary btn-lg px-4">

                        Open Chat
                    </a>
                }
                else
                {
                    <a asp-controller="Account"
                           asp-action="Register"
                           class="btn btn-primary btn-lg px-4">

                        Get Started
                    </a>

                    <a asp-controller="Auth"
                           asp-action="Login"
                           class="btn btn-outline-dark btn-lg px-4">

                        Login
                    </a>
                }

            </div>

            <div class="row mt-5">

                <div class="col-4">
                    <h3 class="fw-bold">⚡</h3>
                    <p class="text-muted">
                        Real-Time Messaging
                    </p>
                </div>

                <div class="col-4">
                    <h3 class="fw-bold">🔒</h3>
                    <p class="text-muted">
                        Secure Authentication
                    </p>
                </div>

                <div class="col-4">
                    <h3 class="fw-bold">☁️</h3>
                    <p class="text-muted">
                        Database Storage
                    </p>
                </div>

            </div>

        </div>

        <div class="col-lg-6 text-center">

            <div class="card shadow-lg border-0 rounded-4 p-4">

                <div class="card-body">

                    <div class="mb-4">

                        <div class="bg-primary text-white rounded-pill px-3 py-2 d-inline-block mb-3">
                            Online Chat
                        </div>

                        <div class="border rounded-4 p-3 text-start mb-3 bg-light">
                            <strong>Rahul</strong>
                            <br />
                            Hey 👋 Welcome to the chat Room!
                        </div>

                        <div class="border rounded-4 p-3 text-start mb-3 bg-primary text-white">
                            <strong>You</strong>
                            <br />
                            Real-time messaging is working 🚀
                        </div>

                        <div class="border rounded-4 p-3 text-start bg-light">
                            <strong>Priya</strong>
                            <br />
                            Built with ASP.NET Core SignalR ❤️
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>