@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-10">

            <div class="text-center mb-5">

                <h1 class="display-4 fw-bold">
                    Privacy Policy
                </h1>

                <p class="lead text-muted">
                    Your privacy and data security are important to us.
                </p>

            </div>


            <div class="card shadow-sm border-0 rounded-4">

                <div class="card-body p-5">

                    <section class="mb-5">

                        <h3 class="fw-bold mb-3">
                            🔒 Information We Collect
                        </h3>

                        <p class="text-muted">
                            We may collect basic account information such as
                            your name, email address, and chat activity to
                            provide and improve our real-time messaging service.
                        </p>

                    </section>


                    <section class="mb-5">

                        <h3 class="fw-bold mb-3">
                            💬 Chat Data
                        </h3>

                        <p class="text-muted">
                            Messages sent within the application may be stored
                            securely in the database to maintain chat history,
                            improve performance, and support future features.
                        </p>

                    </section>


                    <section class="mb-5">

                        <h3 class="fw-bold mb-3">
                            🛡️ Security
                        </h3>

                        <p class="text-muted">
                            We use authentication and authorization mechanisms
                            provided by ASP.NET Core Identity to help protect
                            user accounts and application access.
                        </p>

                    </section>


                    <section class="mb-5">

                        <h3 class="fw-bold mb-3">
                            🍪 Cookies
                        </h3>

                        <p class="text-muted">
                            Authentication cookies may be used to keep users
                            securely signed in and improve user experience.
                        </p>

                    </section>


                    <section class="mb-5">

                        <h3 class="fw-bold mb-3">
                            🔄 Updates to This Policy
                        </h3>

                        <p class="text-muted">
                            This privacy policy may be updated occasionally to
                            reflect improvements, security updates, or new
                            application features.
                        </p>

                    </section>


                    <section>

                        <h3 class="fw-bold mb-3">
                            📧 Contact
                        </h3>

                        <p class="text-muted mb-0">
                            If you have questions regarding this privacy policy,
                            please contact the application administrator.
                        </p>

                    </section>

                </div>

            </div>

        </div>

    </div>

</div>